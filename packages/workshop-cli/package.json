{
  "name": "workshop-cli",
  "version": "1.0.0",
  "private": true,
  "description": "CLI tool for AWS CDK & LocalStack Workshop",
  "type": "module",
  "bin": {
    "workshop": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "workshop": "node scripts/build-check.js && node dist/index.js",
    "workshop:dev": "tsx watch src/index.tsx",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "reset": "node scripts/reset.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "e2e": "tsx scripts/e2e-probelauf.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.600.0",
    "@aws-sdk/client-lambda": "^3.940.0",
    "@aws-sdk/client-sqs": "^3.600.0",
    "@types/inquirer": "^9.0.9",
    "archiver": "^7.0.1",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "cli-highlight": "^2.1.11",
    "diff": "^8.0.2",
    "execa": "^9.3.0",
    "fullscreen-ink": "^0.1.0",
    "ink": "^6.5.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^13.0.1",
    "lodash.debounce": "^4.0.8",
    "ora": "^8.0.1",
    "pg": "^8.12.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.0",
    "unzipper": "^0.12.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/archiver": "^7.0.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.6",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.7",
    "@types/unzipper": "^0.10.11",
    "happy-dom": "^20.0.10",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
