{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "contracts": ["../packages/contracts/src/index.ts"],
      "database-adapter-postgres": ["../packages/database-adapter-postgres/src/index.ts"],
      "queue-adapter-sqs": ["../packages/queue-adapter-sqs/src/index.ts"]
    }
  },
  "include": ["phase*/**/*.ts"]
}
